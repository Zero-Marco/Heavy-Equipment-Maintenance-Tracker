<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.maintenance.LogsMaintenance">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Maintenance Log"
            app:menu="@menu/menu_add_maintenance"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Core Maintenance Details (Required Fields) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Core Details"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp"/>

                    <!-- Equipment Number (Display or Input) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_equipment_number"
                        style="@style/Widget.Material3.TextInputLayout.FilledBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Equipment Number"
                        app:endIconMode="clear_text"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_equipment_number"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:enabled="false"
                            tools:text="EXC0045"
                            android:inputType="textCapCharacters" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <!-- Title (Required Initial Field) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_title"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Maintenance Title (Required)"
                        app:endIconMode="clear_text"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Start Time (Required Initial Field) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Time (Required)"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_time_start"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select Start Date/Time"
                        app:icon="@drawable/ic_calendar_start"
                        app:iconGravity="textStart"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_time_start"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        tools:text="2025-01-20 | 10:30 AM"
                        android:layout_marginBottom="8dp"/>

                    <!-- End Time (Optional Later Field) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="End Time (Optional)"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?android:attr/textColorSecondary"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_time_end"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select End Date/Time"
                        app:icon="@drawable/ic_calendar_end"
                        app:iconGravity="textStart"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_time_end"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        tools:text="2025-01-20 | 11:45 AM"
                        android:layout_marginBottom="8dp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Description (Optional Later Field) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maintenance Description"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Detailed report of work done"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="3"
                            android:gravity="top|start"
                            android:inputType="textMultiLine|textCapSentences" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Costs and Labor (Complex Lists) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parts, Expenses , Labor"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="16dp"/>

                    <!-- Parts Changed -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_parts_changed"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Parts Changed (0 items)"
                        app:icon="@drawable/ic_parts"
                        app:iconGravity="textStart"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:layout_marginBottom="8dp"/>

                    <!-- Other Expenses -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_other_expenses"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Other Expenses (0 items)"
                        app:icon="@drawable/ic_money"
                        app:iconGravity="textStart"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:layout_marginBottom="8dp"/>

                    <!-- Mechanical Engineers/Labor -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_mechanical_engineers"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Engineers , Labor (0 items)"
                        app:icon="@drawable/ic_engineer"
                        app:iconGravity="textStart"
                        android:textAppearance="?attr/textAppearanceBodyLarge"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. Attachments (Image Lists) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attachments (Images)"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:layout_marginBottom="16dp"/>

                    <!-- Damaged Parts Images -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_image_parts_damaged"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Damaged Parts Photos (0 photos)"
                        app:icon="@drawable/ic_parts"
                        app:iconGravity="textStart"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:layout_marginBottom="8dp"/>

                    <!-- Invoice Images -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_image_invoices"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Invoice Photos (0 photos)"
                        app:icon="@drawable/ic_receipt"
                        app:iconGravity="textStart"
                        android:textAppearance="?attr/textAppearanceBodyLarge"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Total Cost/Summary (Optional, can be calculated and displayed here) -->
            <TextView
                android:id="@+id/tv_total_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:padding="8dp"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                tools:text="TOTAL COST: $1,250.00"
                android:layout_marginBottom="16dp"/>

            <!-- Floating Action Button for Save (Alternative to Toolbar Save, if preferred) -->
            <!-- Note: Using the toolbar menu save action for consistency with Material Design -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Placeholder for FAB if needed, but a menu item is usually better for save/done -->
</androidx.coordinatorlayout.widget.CoordinatorLayout>